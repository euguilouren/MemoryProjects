{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-fable-5",
  "permissions": {
    "allow": [
      "Bash(bash sentinela/setup.sh)",
      "Bash(bash sentinela/test.sh)",
      "Bash(bash gerador-pop/check.sh)",
      "Bash(./gradlew:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(git push:*origin main:*)",
      "Bash(git push origin main:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash sentinela/setup.sh",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
