<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRIVACIDADE: nenhuma permissão de INTERNET (o app não envia nada),
         nenhuma de CÂMERA, nenhuma de mídia. O cofre usa o seletor do sistema (SAF). -->

    <!-- Única permissão: ler a lista de apps para o detector de espião exibir nomes legíveis. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <application
        android:name=".App"
        android:allowBackup="false"
        android:hasFragileUserData="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Sentinela">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Sentinela">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
